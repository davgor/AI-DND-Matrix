{
  // Rule relaxations or overrides below require explicit user permission before being changed.
  // Agents must not loosen these on their own — ask first if a rule seems wrong for a specific case.
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "complexity": ["error", { "max": 10 }],
    "max-lines-per-function": ["error", { "max": 50, "skipBlankLines": true }],
    "max-params": ["error", { "max": 4 }],
    "max-depth": ["error", 3]
  },
  "env": {
    "builtin": true
  }
}
