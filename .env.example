# Which LLM provider backs the DM/NPC/party-member agents: "player2", "claude", or "llamacpp"
AGENT_PROVIDER=player2

# Base URL for the local Player2 service
PLAYER2_BASE_URL=http://127.0.0.1:4315

# Required only when AGENT_PROVIDER=claude
CLAUDE_API_KEY=

# llama.cpp local runtime (when AGENT_PROVIDER=llamacpp)
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LLAMA_CPP_SERVER_PATH=
LLAMA_CPP_MODEL_PATH=
LLAMA_CPP_CTX_SIZE=8192
LLAMA_CPP_GPU_LAYERS=all
LLAMA_CPP_START_MODE=attach
