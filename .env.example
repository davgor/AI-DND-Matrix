# Which LLM provider backs the DM/NPC/party-member agents:
# claude | openai | gemini | grok | player2 | llamacpp
AGENT_PROVIDER=player2

# Base URL for the local Player2 service
PLAYER2_BASE_URL=http://127.0.0.1:4315

# Claude (Anthropic) — required when AGENT_PROVIDER=claude (or set in Settings)
CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (GPT) — required when AGENT_PROVIDER=openai (or set in Settings)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Google Gemini — required when AGENT_PROVIDER=gemini (or set in Settings)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# xAI Grok — required when AGENT_PROVIDER=grok (or set in Settings)
GROK_API_KEY=
# XAI_API_KEY=   # alias for GROK_API_KEY
# GROK_MODEL=grok-3

# llama.cpp local runtime (when AGENT_PROVIDER=llamacpp)
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LLAMA_CPP_SERVER_PATH=
LLAMA_CPP_MODEL_PATH=
LLAMA_CPP_CTX_SIZE=8192
LLAMA_CPP_GPU_LAYERS=all
LLAMA_CPP_START_MODE=attach

# Dev only: set to true to always show the first-run settings intro modal
SHOW_POPUP=false
