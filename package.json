{
  "name": "ai-dnd-matrix",
  "version": "0.4.0",
  "private": true,
  "description": "AI-driven single-player text-adventure TTRPG desktop app",
  "repository": {
    "type": "git",
    "url": "https://github.com/davgor/AI-DND-Matrix.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "npm run rebuild:electron",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "prepackage": "npm run rebuild:electron",
    "package": "electron-vite build && electron-builder --win --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "oxlint src",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "terminology:check": "node scripts/terminology-check.mjs",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.10.6",
    "oxlint": "^1.71.0",
    "typescript": "^5.5.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.davgor.aidndmatrix",
    "productName": "AI TTRPG Matrix",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "davgor",
      "repo": "AI-DND-Matrix"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  }
}
